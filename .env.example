# ==========================================
# Nigehbaan — Environment Variables
# Copy to .env and fill in actual values
# ==========================================

# Database (Neon PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://neondb_owner:<password>@ep-<endpoint>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Redis (Task Queue)
REDIS_URL=redis://localhost:6379/0

# Mapbox
MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# API
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,https://nigehbaan.pk

# Security
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# AWS S3 (Raw data storage)
S3_BUCKET=nigehbaan-data
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Firecrawl (self-hosted web scraping API — bypasses WAF, renders JS, extracts structured data)
FIRECRAWL_API_URL=http://your-firecrawl-host:3002
FIRECRAWL_API_KEY=

# OpenAI / OpenRouter (AI extraction from news articles)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini

# External Neon DB (court judgments import — READ ONLY)
EXTERNAL_JUDGMENTS_DB_URL=postgresql://user:pass@host/db?sslmode=require

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# Frontend (prefixed with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
NEXT_PUBLIC_API_URL=http://localhost:8000
